<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>World Cup Predictor App</title>
    <style>
        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        body {
            background-color: #0f172a;
            color: #f8fafc;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            margin: 0;
            padding: 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }
        .app-container {
            width: 100%;
            max-width: 460px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        .alert {
            padding: 14px;
            border-radius: 12px;
            text-align: center;
            font-size: 14px;
            font-weight: 600;
        }
        .alert-success {
            background-color: rgba(16, 185, 129, 0.15);
            color: #a7f3d0;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }
        .alert-danger {
            background-color: rgba(239, 68, 68, 0.15);
            color: #fca5a5;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        .card {
            background-color: #1e293b;
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
            border: 1px solid #334155;
        }
        .header h2 {
            margin: 0;
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }
        .header p {
            color: #94a3b8;
            font-size: 14px;
            margin: 6px 0 24px 0;
        }
        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            color: #94a3b8;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        input[type="text"], select {
            width: 100%;
            background-color: #0f172a;
            border: 1px solid #334155;
            border-radius: 12px;
            padding: 14px;
            color: #ffffff;
            font-size: 16px;
            font-weight: 500;
            outline: none;
        }
        .scoreboard {
            display: flex;
            background-color: #0f172a;
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 16px;
            align-items: center;
            justify-content: space-around;
        }
        input[type="number"] {
            width: 72px;
            height: 54px;
            text-align: center;
            background-color: #1e293b;
            border: 1px solid #475569;
            border-radius: 10px;
            color: #ffffff;
            font-size: 24px;
            font-weight: 700;
            outline: none;
        }
        .divider {
            font-size: 20px;
            color: #475569;
            font-weight: 700;
            margin-bottom: 4px;
        }
        .btn-submit {
            width: 100%;
            background-color: #10b981;
            color: #0f172a;
            font-size: 16px;
            font-weight: 700;
            padding: 16px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
        }
        .section-title {
            margin: 10px 0 0 0;
            font-size: 18px;
            font-weight: 800;
            color: #e2e8f0;
            border-bottom: 1px solid #334155;
            padding-bottom: 8px;
        }
        .list-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-top: 14px;
        }
        .entry-card {
            background-color: #1e293b;
            border: 1px solid #334155;
            border-radius: 14px;
            padding: 14px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .player-info { display: flex; flex-direction: column; gap: 4px; }
        .player-name { font-weight: 700; font-size: 15px; color: #10b981; }
        .match-name { font-size: 13px; color: #cbd5e1; }
        .timestamp { font-size: 11px; color: #64748b; }
        .score-side {
            background-color: #0f172a;
            border: 1px solid #334155;
            border-radius: 10px;
            padding: 8px 14px;
            font-size: 16px;
            font-weight: 800;
            color: #ffffff;
            font-family: monospace;
        }
        .empty-state { text-align: center; color: #64748b; padding: 24px 0; font-size: 13px; }
        .admin-box {
            margin-top: 16px;
            border-top: 1px dashed #334155;
            padding-top: 16px;
        }
        .clear-form { display: flex; gap: 8px; }
        .password-input {
            flex: 1;
            background-color: #0f172a;
            border: 1px solid #334155;
            border-radius: 10px;
            padding: 0 12px;
            color: #ffffff;
            font-size: 13px;
            outline: none;
            height: 42px;
        }
        .btn-danger {
            background-color: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border: 1px solid rgba(248, 113, 113, 0.3);
            border-radius: 10px;
            padding: 0 16px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            height: 42px;
        }
    </style>
</head>
<body>

    <div class="app-container">
        
        <!-- Status Feedback Notifications -->
        <% if (locals.success) { %>
            <div class="alert alert-success">🚀 Prediction submitted successfully!</div>
        <% } %>
        <% if (locals.clearSuccess) { %>
            <div class="alert alert-success">🧹 Database logs successfully cleared.</div>
        <% } %>
        <% if (locals.error === 'invalid_password') { %>
            <div class="alert alert-danger">❌ Incorrect admin password. Access denied.</div>
        <% } %>

        <!-- SECTION 1: Prediction Entry Form Dropdown -->
        <div class="card">
            <div class="header">
                <h2>World Cup Pool</h2>
                <p>Enter your prediction for the next matchup</p>
            </div>
            
            <form action="/submit-bet" method="POST">
                <div class="form-group">
                    <label>Your Name</label>
                    <input type="text" name="username" required placeholder="Enter your name...">
                </div>

                <div class="form-group">
                    <label>Matchup</label>
                    <select name="match">
                        <% matches.forEach(match => { %>
                            <option value="<%= match %>"><%= match %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label>Predicted Score</label>
                    <div class="scoreboard">
                        <div class="score-input-group">
                            <input type="number" name="scoreA" min="0" required value="0">
                        </div>
                        <div class="divider">:</div>
                        <div class="score-input-group">
                            <input type="number" name="scoreB" min="0" required value="0">
                        </div>
                    </div>
                </div>

                <button type="submit" class="submit-btn btn-submit">Submit Score</button>
            </form>
        </div>

        <!-- SECTION 2: Live Leaderboard Logs Grid -->
        <div class="card">
            <h3 class="section-title">Live Standings Logs</h3>
            
            <div class="list-container">
                <% if (bets.length === 0) { %>
                    <div class="empty-state">No score logs found yet. Be the first!</div>
                <% } else { %>
                    <% bets.forEach(bet => { %>
                        <div class="entry-card">
                            <div class="player-info">
                                <span class="player-name"><%= bet.name %></span>
                                <span class="match-name">⚽ <%= bet.game %></span>
                                <span class="timestamp">Logged at <%= bet.timestamp %></span>
                            </div>
                            <div class="score-side">
                                <%= bet.score %>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <!-- SECTION 3: Integrated Password Clearance Gate -->
            <div class="admin-box">
                <form action="/admin/clear-data" method="POST" class="clear-form" onsubmit="return confirm('Clear ALL data logs?');">
                    <input type="password" name="adminPassword" required placeholder="Admin Password..." class="password-input">
                    <button type="submit" class="btn-danger">Clear All</button>
                </form>
            </div>
        </div>

    </div>

</body>
</html>
