<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>World Cup Live Betting Predictor</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }
        body {
            background: linear-gradient(180deg, rgba(11, 19, 43, 0.95) 0%, rgba(11, 19, 43, 0.98) 100%), 
                        url('https://unsplash.com');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: #f1f5f9;
            min-height: 100vh;
            padding: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .app-container {
            width: 100%;
            max-width: 430px;
            display: flex;
            flex-direction: column;
            gap: 14px;
        }
        .app-header {
            text-align: center;
            padding: 16px 0 8px 0;
        }
        .app-header h1 {
            font-size: 26px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 4px 12px rgba(79, 172, 254, 0.2);
        }
        .app-header p {
            font-size: 13px;
            color: #64748b;
            margin-top: 4px;
            font-weight: 500;
        }
        .alert {
            padding: 14px;
            border-radius: 14px;
            text-align: center;
            font-size: 14px;
            font-weight: 700;
            animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .alert-success {
            background: rgba(16, 185, 129, 0.15);
            color: #34d399;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }
        .alert-danger {
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        .bet-slip-card {
            background: rgba(26, 36, 65, 0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 20px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.35);
        }
        .slip-title {
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #00f2fe;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .slip-title::before {
            content: '';
            display: inline-block;
            width: 6px;
            height: 6px;
            background-color: #00f2fe;
            border-radius: 50%;
            box-shadow: 0 0 8px #00f2fe;
        }
        .input-group {
            margin-bottom: 18px;
        }
        .input-label {
            display: block;
            font-size: 11px;
            font-weight: 800;
            color: #94a3b8;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        input[type="text"] {
            width: 100%;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            padding: 14px 16px;
            color: #ffffff;
            font-size: 15px;
            font-weight: 600;
            outline: none;
            transition: all 0.2s;
        }
        input[type="text"]:focus {
            border-color: #4facfe;
            background: rgba(15, 23, 42, 0.85);
            box-shadow: 0 0 14px rgba(79, 172, 254, 0.15);
        }
        .match-chips-container {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .match-chip {
            background: rgba(15, 23, 42, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 14px;
            padding: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 14px;
            font-weight: 700;
            color: #cbd5e1;
            transition: all 0.2s;
        }
        .match-chip.selected {
            background: linear-gradient(135deg, rgba(79, 172, 254, 0.15) 0%, rgba(0, 242, 254, 0.05) 100%);
            border-color: #00f2fe;
            color: #ffffff;
            box-shadow: 0 4px 20px rgba(0, 242, 254, 0.1);
        }
        .slip-scoreboard {
            display: flex;
            background: rgba(15, 23, 42, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 18px;
            padding: 16px;
            align-items: center;
            justify-content: space-around;
        }
        .side-incrementer {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }
        .team-title-span {
            font-size: 11px;
            font-weight: 800;
            color: #64748b;
            text-transform: uppercase;
        }
        .controls-row {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .math-control-btn {
            width: 38px;
            height: 38px;
            border-radius: 12px;
            background: #1e293b;
            border: 1px solid rgba(255, 255, 255, 0.08);
            color: #ffffff;
            font-size: 20px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .numerical-count {
            font-size: 34px;
            font-weight: 900;
            width: 36px;
            text-align: center;
            color: #ffffff;
            font-family: monospace;
        }
        .slip-center-colon {
            font-size: 22px;
            color: #475569;
            font-weight: 900;
            margin-top: 18px;
        }
        .btn-lock-bet {
            width: 100%;
            background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
            color: #0b132b;
            font-size: 16px;
            font-weight: 800;
            padding: 16px;
            border: none;
            border-radius: 14px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            box-shadow: 0 8px 24px rgba(79, 172, 254, 0.25);
            margin-top: 14px;
        }
        .live-ticker-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .ticker-row-card {
            background: rgba(15, 23, 42, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 16px;
            padding: 14px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .ticker-left-info {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }
        .ticker-player-name { font-weight: 800; font-size: 15px; color: #10b981; }
        .ticker-game-text { font-size: 13px; color: #e2e8f0; font-weight: 600; }
        .ticker-time { font-size: 10px; color: #64748b; }
        .ticker-score-badge {
            background: #0f172a;
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            padding: 8px 14px;
            font-size: 16px;
            font-weight: 900;
            color: #00f2fe;
            font-family: monospace;
        }
        .empty-state { text-align: center; color: #475569; padding: 32px 0; font-size: 13px; font-weight: 600; }
        .admin-footer-gate { margin-top: 14px; border-top: 1px dashed rgba(255, 255, 255, 0.08); padding-top: 14px; }
        .gate-layout-form { display: flex; gap: 8px; }
        .gate-pass-field { flex: 1; background: rgba(15, 23, 42, 0.7); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 10px; padding: 0 12px; color: #ffffff; font-size: 13px; outline: none; height: 40px; }
        .btn-wipe-board { background-color: rgba(239, 68, 68, 0.15); color: #f87171; border: 1px solid rgba(248, 113, 113, 0.25); border-radius: 10px; padding: 0 16px; font-size: 12px; font-weight: 800; cursor: pointer; height: 40px; text-transform: uppercase; }
    </style>
</head>
<body>

    <div class="app-container">
        <div class="app-header">
            <h1>🏆 Arena Predictor</h1>
            <p>Lock your scoreline slip & track live standings</p>
        </div>
        
        <% if (success) { %>
            <div class="alert alert-success">🥅 Bet slip successfully submitted to active pools!</div>
        <% } %>
        <% if (clearSuccess) { %>
            <div class="alert alert-success">🧹 Active leaderboard records safely cleared.</div>
        <% } %>
        <% if (error === 'invalid_password') { %>
            <div class="alert alert-danger">❌ Operation Denied: Security Key Unaligned.</div>
        <% } %>

        <div class="bet-slip-card">
            <div class="slip-title">Active Betting Slip</div>
            
            <form action="/submit-bet" method="POST">
                <div class="input-group">
                    <label class="input-label">Runner Identity Name</label>
