<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>World Cup Predictor</title>
    <style>
        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }
        body {
            background-color: #0f172a;
            color: #f8fafc;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .app-container {
            width: 100%;
            max-width: 440px;
        }
        .alert {
            background-color: #065f46;
            color: #a7f3d0;
            padding: 16px;
            border-radius: 12px;
            text-align: center;
            margin-bottom: 16px;
            font-size: 14px;
            font-weight: 600;
        }
        .card {
            background-color: #1e293b;
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
        }
        .header h2 {
            margin: 0;
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -0.5px;
        }
        .header p {
            color: #94a3b8;
            font-size: 14px;
            margin: 6px 0 24px 0;
        }
        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            font-size: 12px;
            font-weight: 700;
            color: #94a3b8;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        input[type="text"], select {
            width: 100%;
            background-color: #0f172a;
            border: 1px solid #334155;
            border-radius: 12px;
            padding: 14px;
            color: #ffffff;
            font-size: 16px;
            font-weight: 500;
            outline: none;
            transition: border-color 0.2s;
            appearance: none;
        }
        input[type="text"]:focus, select:focus {
            border-color: #10b981;
        }
        .select-wrapper {
            position: relative;
        }
        .select-wrapper::after {
            content: "▼";
            font-size: 10px;
            color: #64748b;
            position: absolute;
            right: 16px;
            top: 18px;
            pointer-events: none;
        }
        .scoreboard {
            display: flex;
            background-color: #0f172a;
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 16px;
            align-items: center;
            justify-content: space-around;
        }
        .score-input-group {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .score-label {
            font-size: 11px;
            color: #64748b;
            font-weight: 700;
            text-transform: uppercase;
            margin-bottom: 6px;
        }
        input[type="number"] {
            width: 72px;
            height: 54px;
            text-align: center;
            background-color: #1e293b;
            border: 1px solid #475569;
            border-radius: 10px;
            color: #ffffff;
            font-size: 24px;
            font-weight: 700;
            outline: none;
        }
        input[type="number"]:focus {
            border-color: #10b981;
        }
        .divider {
            font-size: 20px;
            color: #475569;
            font-weight: 700;
            align-self: flex-end;
            margin-bottom: 12px;
        }
        button {
            width: 100%;
            background-color: #10b981;
            color: #0f172a;
            font-size: 16px;
            font-weight: 700;
            padding: 16px;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            margin-top: 8px;
            transition: background-color 0.2s;
        }
        button:active {
            background-color: #059669;
        }
    </style>
</head>
<body>

    <div class="app-container">
        <% if (success) { %>
            <div class="alert">Prediction saved!</div>
        <% } %>

        <div class="card">
            <div class="header">
                <h2>World Cup Pool</h2>
                <p>Enter your prediction for the next matchup</p>
            </div>
            
            <form action="/submit-bet" method="POST">
                <div class="form-group">
                    <label>Your Name</label>
                    <input type="text" name="username" required placeholder="Enter your name...">
                </div>

                <div class="form-group">
                    <label>Matchup</label>
                    <div class="select-wrapper">
                        <select name="match">
                            <% matches.forEach(match => { %>
                                <option value="<%= match %>"><%= match %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Predicted Score</label>
                    <div class="scoreboard">
                        <div class="score-input-group">
                            <span class="score-label">Team A</span>
                            <input type="number" name="scoreA" min="0" required value="0">
                        </div>
                        <div class="divider">:</div>
                        <div class="score-input-group">
                            <span class="score-label">Team B</span>
                            <input type="number" name="scoreB" min="0" required value="0">
                        </div>
                    </div>
                </div>

                <button type="submit">Submit Score</button>
            </form>
        </div>
    </div>

</body>
</html>
