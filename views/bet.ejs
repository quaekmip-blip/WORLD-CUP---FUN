<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>World Cup Predictor App</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }
        body {
            /* Immersive football stadium theme background */
            background: linear-gradient(180px, rgba(15, 23, 42, 0.85) 0%, rgba(15, 23, 42, 0.95) 100%), 
                        url('https://unsplash.com');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: #f8fafc;
            min-height: 100vh;
            padding: 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        .app-container {
            width: 100%;
            max-width: 440px;
            display: flex;
            flex-direction: column;
            gap: 16px;
            padding-bottom: 30px;
        }
        .app-title-card {
            text-align: center;
            padding: 12px 0;
        }
        .app-title-card h1 {
            font-size: 26px;
            font-weight: 900;
            background: linear-gradient(to right, #38bdf8, #10b981);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-transform: uppercase;
            letter-spacing: -0.5px;
        }
        .app-title-card p {
            font-size: 13px;
            color: #94a3b8;
            margin-top: 4px;
        }
        .alert {
            padding: 14px;
            border-radius: 12px;
            text-align: center;
            font-size: 14px;
            font-weight: 700;
            animation: slideIn 0.3s ease-out;
        }
        .alert-success {
            background-color: rgba(16, 185, 129, 0.2);
            color: #a7f3d0;
            border: 1px solid rgba(16, 185, 129, 0.4);
        }
        .alert-danger {
            background-color: rgba(239, 68, 68, 0.2);
            color: #fca5a5;
            border: 1px solid rgba(239, 68, 68, 0.4);
        }
        .card {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 24px;
            padding: 20px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }
        .card-title {
            font-size: 16px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #38bdf8;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .form-group {
            margin-bottom: 16px;
        }
        label {
            display: block;
            font-size: 11px;
            font-weight: 800;
            color: #94a3b8;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        input[type="text"], select {
            width: 100%;
            background-color: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 14px;
            padding: 14px;
            color: #ffffff;
            font-size: 15px;
            font-weight: 600;
            outline: none;
            transition: all 0.2s;
        }
        input[type="text"]:focus, select:focus {
            border-color: #38bdf8;
            background-color: rgba(15, 23, 42, 0.9);
        }
        
        /* Interactive Mobile Score Clickers */
        .interactive-scoreboard {
            display: flex;
            background-color: rgba(15, 23, 42, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 18px;
            padding: 16px;
            align-items: center;
            justify-content: space-around;
        }
        .team-clicker-group {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }
        .team-label {
            font-size: 12px;
            font-weight: 800;
            color: #94a3b8;
        }
        .counter-controls {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .click-btn {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background-color: #334155;
            color: #ffffff;
            font-size: 18px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.1s;
        }
        .click-btn:active {
            transform: scale(0.9);
            background-color: #475569;
        }
        .score-display {
            font-size: 32px;
            font-weight: 900;
            width: 40px;
            text-align: center;
            font-family: monospace;
            color: #ffffff;
        }
        .score-divider {
            font-size: 24px;
            color: #475569;
            font-weight: 800;
        }
        .btn-submit {
            width: 100%;
            background: linear-gradient(135px, #10b981 0%, #059669 100%);
            color: #0f172a;
            font-size: 16px;
            font-weight: 800;
            padding: 16px;
            border: none;
            border-radius: 14px;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(16, 185, 129, 0.3);
            transition: all 0.2s;
        }
        .btn-submit:active {
            transform: scale(0.98);
            box-shadow: 0 2px 6px rgba(16, 185, 129, 0.2);
        }
        
        /* Live Dynamic Feed List Cards Layout */
        .list-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .entry-card {
            background: rgba(15, 23, 42, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 12px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            animation: fadeIn 0.3s ease-out;
        }
        .player-info {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .player-name {
            font-weight: 800;
            font-size: 15px;
            color: #10b981;
        }
        .match-name {
            font-size: 13px;
            color: #cbd5e1;
            font-weight: 500;
        }
        .timestamp {
            font-size: 10px;
            color: #64748b;
        }
        .score-badge {
            background: linear-gradient(135px, #334155 0%, #1e293b 100%);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 8px 14px;
            font-size: 16px;
            font-weight: 900;
            color: #38bdf8;
            font-family: monospace;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.3);
        }
        .empty-state {
            text-align: center;
            color: #64748b;
            padding: 30px 0;
            font-size: 13px;
            font-weight: 500;
        }
        
        /* Integrated Security Panel Footer */
        .admin-box {
            margin-top: 16px;
            border-top: 1px dashed rgba(255, 255, 255, 0.1);
            padding-top: 16px;
        }
        .clear-form {
            display: flex;
            gap: 8px;
        }
        .password-input {
            flex: 1;
            background-color: rgba(15, 23, 42, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 0 12px;
            color: #ffffff;
            font-size: 13px;
            outline: none;
            height: 40px;
        }
        .btn-danger {
            background-color: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border: 1px solid rgba(248, 113, 113, 0.3);
            border-radius: 10px;
            padding: 0 16px;
            font-size: 12px;
            font-weight: 800;
            cursor: pointer;
            height: 40px;
        }
        
        @keyframes slideIn {
            from { transform: translateY(-10px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.98); }
            to { opacity: 1; transform: scale(1); }
        }
    </style>
</head>
<body>

    <div class="app-container">
        
        <div class="app-title-card">
            <h1>🏆 World Cup Predictor</h1>
            <p>Lock in predictions & track results</p>
        </div>
        
        <!-- Status Messages -->
        <% if (success) { %>
            <div class="alert alert-success">⚽ Prediction logged perfectly!</div>
        <% } %>
        <% if (clearSuccess) { %>
            <div class="alert alert-success">🧹 Standings board safely reset.</div>
        <% } %>
        <% if (error === 'invalid_password') { %>
            <div class="alert alert-danger">❌ Access Denied: Invalid Password.</div>
        <% } %>

        <!-- CARD 1: Submit Entry Prediction -->
        <div class="card">
            <div class="card-title">🟢 Submit Prediction</div>
            
            <form action="/submit-bet" method="POST">
                <div class="form-group">
                    <label>Your Name</label>
