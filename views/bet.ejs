<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>World Cup Premium Arena</title>
    <style>
        :root {
            --bg-main: #060b19;
            --card-bg: rgba(15, 23, 42, 0.6);
            --neon-blue: #00f2fe;
            --neon-green: #10b981;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --border-glow: rgba(255, 255, 255, 0.06);
        }
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, sans-serif;
        }
        body {
            background: radial-gradient(circle at top, #0f2042 0%, var(--bg-main) 70%), 
                        url('https://unsplash.com');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: var(--text-primary);
            min-height: 100vh;
            padding: 20px 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
        }
        .app-container {
            width: 100%;
            max-width: 420px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        .app-header {
            text-align: center;
            padding: 8px 0;
        }
        .app-header h1 {
            font-size: 26px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: linear-gradient(135deg, var(--neon-blue) 0%, #4facfe 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 2px 8px rgba(0, 242, 254, 0.25));
        }
        .app-header p {
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 4px;
            font-weight: 600;
        }
        .alert {
            padding: 14px;
            border-radius: 16px;
            text-align: center;
            font-size: 14px;
            font-weight: 700;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            animation: slideIn 0.3s ease-out;
        }
        .alert-success {
            background: rgba(16, 185, 129, 0.15);
            color: #34d399;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }
        .alert-danger {
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        .bet-slip-card {
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 24px;
            padding: 20px;
            border: 1px solid var(--border-glow);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        }
        .slip-title {
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--neon-blue);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .slip-title::before {
            content: '';
            width: 6px;
            height: 6px;
            background-color: var(--neon-blue);
            border-radius: 50%;
            box-shadow: 0 0 8px var(--neon-blue);
        }
        .input-group {
            margin-bottom: 18px;
        }
        .input-label {
            display: block;
            font-size: 11px;
            font-weight: 800;
            color: var(--text-secondary);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        input[type="text"] {
            width: 100%;
            background: rgba(10, 15, 30, 0.5);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            padding: 14px;
            color: #ffffff;
            font-size: 15px;
            font-weight: 600;
            outline: none;
            transition: all 0.2s;
        }
        input[type="text"]:focus {
            border-color: var(--neon-blue);
            background: rgba(10, 15, 30, 0.8);
        }
        .match-chips-container {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .match-chip {
            background: rgba(10, 15, 30, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 14px;
            padding: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 14px;
            font-weight: 700;
            color: #cbd5e1;
            transition: all 0.2s;
        }
        .match-chip.selected {
            background: linear-gradient(135deg, rgba(0, 242, 254, 0.15) 0%, rgba(79, 172, 254, 0.03) 100%);
            border-color: var(--neon-blue);
            color: #ffffff;
            box-shadow: 0 4px 16px rgba(0, 242, 254, 0.1);
        }
        .slip-scoreboard {
            display: flex;
            background: rgba(10, 15, 30, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 20px;
            padding: 16px;
            align-items: center;
            justify-content: space-around;
        }
        .side-incrementer {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }
        .team-title-span {
            font-size: 11px;
            font-weight: 800;
            color: var(--text-secondary);
            text-transform: uppercase;
        }
        .controls-row {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .math-control-btn {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #192239;
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: #ffffff;
            font-size: 20px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .math-control-btn:active {
            background: #232f4e;
            border-color: var(--neon-blue);
        }
        .numerical-count {
            font-size: 36px;
            font-weight: 900;
            width: 36px;
            text-align: center;
            color: #ffffff;
            font-family: monospace;
        }
        .slip-center-colon {
            font-size: 22px;
            color: #3b4f76;
            font-weight: 900;
            margin-top: 20px;
        }
        .btn-lock-bet {
            width: 100%;
            background: linear-gradient(135deg, var(--neon-blue) 0%, #4facfe 100%);
            color: #060b19;
            font-size: 16px;
            font-weight: 800;
            padding: 16px;
            border: none;
            border-radius: 14px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            box-shadow: 0 8px 20px rgba(0, 242, 254, 0.2);
            margin-top: 14px;
        }
        .btn-lock-bet:active {
            transform: scale(0.98);
        }
        .live-ticker-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .ticker-row-card {
            background: rgba(10, 15, 30, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 16px;
            padding: 12px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .ticker-left-info {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }
        .ticker-player-name { font-weight: 800; font-size: 15px; color: var(--neon-green); }
        .ticker-game-text { font-size: 13px; color: #e2e8f0; font-weight: 600; }
        .ticker-time { font-size: 10px; color: #64748b; }
        .ticker-score-badge {
            background: #060b19;
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 12px;
            padding: 8px 14px;
            font-size: 16px;
            font-weight: 900;
            color: var(--neon-blue);
            font-family: monospace;
        }
        .empty-state { text-align: center; color: #475569; padding: 32px 0; font-size: 13px; font-weight: 600; }
        .admin-footer-gate { margin-top: 14px; border-top: 1px dashed rgba(255, 255, 255, 0.08); padding-top: 14px; }
        .gate-layout-form { display: flex; gap: 8px; }
        .gate-pass-field { flex: 1; background: rgba(10, 15, 30, 0.7); border: 1px solid rgba(255, 255, 255, 0.06); border-radius: 12px; padding: 0 14px; color: #ffffff; font-size: 13px; outline: none; height: 44px; }
        .btn-wipe-board { background-color: rgba(239, 68, 68, 0.12); color: #f87171; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 12px; padding: 0 18px; font-size: 12px; font-weight: 800; cursor: pointer; height: 44px; text-transform: uppercase; }
        @keyframes slideIn { from { transform: translateY(-10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    </style>
</head>
<body>

    <div class="app-container">
        <div class="app-header">
            <h1>⚽ Arena Predictor</h1>
            <p>Lock your scoreline slip & track live standings</p>
        </div>
        
