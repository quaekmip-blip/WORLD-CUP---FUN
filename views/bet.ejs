<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>World Cup Premium Arena</title>
    <style>
        :root {
            --bg-main: #060b19;
            --card-bg: rgba(15, 23, 42, 0.55);
            --neon-blue: #00f2fe;
            --neon-green: #10b981;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --border-glow: rgba(255, 255, 255, 0.08);
        }
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", Roboto, Helvetica, sans-serif;
        }
        body {
            background: radial-gradient(circle at top, #0f2042 0%, var(--bg-main) 70%), 
                        url('https://unsplash.com');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: var(--text-primary);
            min-height: 100vh;
            padding: 20px 16px;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
        }
        .app-container {
            width: 100%;
            max-width: 420px;
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        .app-header {
            text-align: center;
            padding: 10px 0;
        }
        .app-header h1 {
            font-size: 28px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 1px;
            background: linear-gradient(135deg, var(--neon-blue) 0%, #4facfe 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 2px 8px rgba(0, 242, 254, 0.3));
        }
        .app-header p {
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 4px;
            font-weight: 600;
            letter-spacing: 0.3px;
        }
        .alert {
            padding: 14px;
            border-radius: 16px;
            text-align: center;
            font-size: 14px;
            font-weight: 700;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
            animation: slideIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
        }
        .alert-success {
            background: rgba(16, 185, 129, 0.12);
            color: #34d399;
            border: 1px solid rgba(16, 185, 129, 0.3);
        }
        .alert-danger {
            background: rgba(239, 68, 68, 0.12);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }
        .bet-slip-card {
            background: var(--card-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-radius: 28px;
            padding: 22px;
            border: 1px solid var(--border-glow);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        .slip-title {
            font-size: 11px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--neon-blue);
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .slip-title::before {
            content: '';
            width: 6px;
            height: 6px;
            background-color: var(--neon-blue);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--neon-blue);
        }
        .input-group {
            margin-bottom: 20px;
        }
        .input-label {
            display: block;
            font-size: 11px;
            font-weight: 800;
            color: var(--text-secondary);
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.8px;
        }
        input[type="text"] {
            width: 100%;
            background: rgba(10, 15, 30, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 16px;
            padding: 16px;
            color: #ffffff;
            font-size: 16px;
            font-weight: 600;
            outline: none;
            transition: all 0.25s ease;
        }
        input[type="text"]:focus {
            border-color: var(--neon-blue);
            background: rgba(10, 15, 30, 0.85);
            box-shadow: 0 0 16px rgba(0, 242, 254, 0.15);
        }
        .match-chips-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .match-chip {
            background: rgba(10, 15, 30, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            padding: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            font-size: 15px;
            font-weight: 700;
            color: #cbd5e1;
            transition: all 0.25s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .match-chip .versus-badge {
            font-size: 10px;
            font-weight: 900;
            background: rgba(255, 255, 255, 0.08);
            padding: 4px 8px;
            border-radius: 8px;
            color: var(--text-secondary);
        }
        .match-chip.selected {
            background: linear-gradient(135deg, rgba(0, 242, 254, 0.12) 0%, rgba(79, 172, 254, 0.03) 100%);
            border-color: var(--neon-blue);
            color: #ffffff;
            box-shadow: 0 8px 24px rgba(0, 242, 254, 0.12);
            transform: scale(1.01);
        }
        .match-chip.selected .versus-badge {
            background: var(--neon-blue);
            color: #060b19;
        }
        .slip-scoreboard {
            display: flex;
            background: rgba(10, 15, 30, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.04);
            border-radius: 22px;
            padding: 18px;
            align-items: center;
            justify-content: space-around;
        }
        .side-incrementer {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }
        .team-title-span {
            font-size: 11px;
            font-weight: 800;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .controls-row {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .math-control-btn {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: #192239;
            border: 1px solid rgba(255, 255, 255, 0.06);
            color: #ffffff;
            font-size: 22px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .math-control-btn:active {
            transform: scale(0.9);
            background: #232f4e;
            border-color: var(--neon-blue);
        }
        .numerical-count {
            font-size: 38px;
            font-weight: 900;
            width: 40px;
            text-align: center;
            color: #ffffff;
            font-family: monospace;
        }
        .slip-center-colon {
            font-size: 24px;
            color: #3b4f76;
            font-weight: 900;
            margin-top: 22px;
        }
        .btn-lock-bet {
            width: 100%;
            background: linear-gradient(135deg, var(--neon-blue) 0%, #4facfe 100%);
            color: #060b19;
            font-size: 16px;
            font-weight: 800;
            padding: 18px;
            border: none;
            border-radius: 16px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            box-shadow: 0 10px 25px rgba(0, 242, 254, 0.25);
            margin-top: 14px;
        }
        .live-ticker-container {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .ticker-row-card {
            background: rgba(10, 15, 30, 0.35);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 18px;
            padding: 14px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .ticker-left-info {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .ticker-player-name {
            font-weight: 800;
            font-size: 16px;
            color: var(--neon-green);
        }
        .ticker-game-text {
            font-size: 13px;
            color: #e2e8f0;
            font-weight: 600;
        }
        .ticker-time {
            font-size: 10px;
            color: #475569;
        }
        .ticker-score-badge {
            background: #060b19;
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 14px;
            padding: 10px 16px;
            font-size: 17px;
            font-weight: 900;
            color: var(--neon-blue);
            box-shadow: inset 0 2px 6px rgba(0,0,0,0.6);
            letter-spacing: 0.5px;
        }
        .empty-state {
            text-align: center;
            color: #475569;
            padding: 40px 0;
            font-size: 14px;
            font-weight: 600;
        }
        .admin-footer-gate {
            margin-top: 16px;
