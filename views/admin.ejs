<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prediction Dashboard</title>
    <style>
        * {
            box-sizing: border-box;
        }
        body {
            background-color: #0f172a;
            color: #f8fafc;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            margin: 0;
            padding: 16px;
            display: flex;
            justify-content: center;
        }
        .container {
            width: 100%;
            max-width: 600px;
        }
        .header {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 24px;
            border-bottom: 1px solid #334155;
            padding-bottom: 16px;
        }
        h1 {
            margin: 0;
            font-size: 24px;
            font-weight: 800;
        }
        .nav-row {
            display: flex;
            gap: 8px;
            width: 100%;
        }
        .btn {
            flex: 1;
            text-align: center;
            padding: 12px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            border: none;
            cursor: pointer;
        }
        .btn-secondary {
            background-color: #1e293b;
            color: #f8fafc;
            border: 1px solid #334155;
        }
        .btn-danger {
            background-color: #1e293b;
            color: #f87171;
            border: 1px solid rgba(248, 113, 113, 0.3);
        }
        .list-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .entry-card {
            background-color: #1e293b;
            border: 1px solid #334155;
            border-radius: 14px;
            padding: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .info-side {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .player-name {
            font-weight: 700;
            font-size: 16px;
            color: #10b981;
        }
        .match-name {
            font-size: 14px;
            color: #e2e8f0;
        }
        .timestamp {
            font-size: 11px;
            color: #64748b;
        }
        .score-side {
            background-color: #0f172a;
            border: 1px solid #334155;
            border-radius: 10px;
            padding: 10px 18px;
            font-size: 18px;
            font-weight: 800;
            letter-spacing: 1px;
            color: #ffffff;
        }
        .empty-state {
            text-align: center;
            color: #64748b;
            padding: 48px 16px;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="header">
            <div>
                <h1>Prediction Logs</h1>
            </div>
            <div class="nav-row">
                <a href="/" class="btn btn-secondary">← Form Page</a>
                <form action="/admin/clear-data" method="POST" onsubmit="return confirm('Clear all data logs?');" style="flex: 1; display: flex;">
                    <button type="submit" class="btn btn-danger" style="width: 100%;">Clear All</button>
                </form>
            </div>
        </div>

        <div class="list-container">
            <% if (bets.length === 0) { %>
                <div class="empty-state">No score logs found yet.</div>
            <% } else { %>
                <% [...bets].reverse().forEach(bet => { %>
                    <div class="entry-card">
                        <div class="info-side">
                            <span class="player-name"><%= bet.name %></span>
                            <span class="match-name"><%= bet.game %></span>
                            <span class="timestamp">Logged at <%= bet.timestamp %></span>
                        </div>
                        <div class="score-side">
                            <%= bet.score %>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

</body>
</html>
